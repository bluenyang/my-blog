{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": true,
  "trailingComma": "all",
  "bracketSpacing": true,
  "arrowParens": "always",
  "endOfLine": "lf",
  "vueIndentScriptAndStyle": true,
  "sortPackageJson": false,
  "sortTailwindcss": {},
  "ignorePatterns": [
    "node_modules",
    "dist",
    "coverage",
    "build",
    ".stversions",
    "package.json",
    "yarn.lock",
    ".turbo",
    ".oxlintrc.json",
    ".oxfmtrc.json"
  ]
}
