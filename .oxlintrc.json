    "require-yield": "error",
    "use-isnan": "error",
    "valid-typeof": "error",
    "import/first": "error",
    "import/no-duplicates": "error",
    "import/no-mutable-exports": "error",
    "import/no-named-default": "error",
    "import/newline-after-import": [
